# ---------------------------------------------------------------------------
# RADONAIX Revenue Assurance backend — environment configuration
# Copy to `.env` and adjust. Never commit a real `.env`.
# ---------------------------------------------------------------------------

# --- General ---
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true
API_PREFIX=/api
# Comma-separated allowed origins (the Lovable UI dev server). "*" for all (dev only).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# --- Auth / JWT ---
# Generate a strong secret, e.g.  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-please-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
BOOTSTRAP_ADMIN_EMAIL=admin@radonaix.io
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!123
# Password assigned to the non-admin demo accounts created by the seeder.
DEMO_PASSWORD=ChangeMe!123

# --- App database (owned by this service) ---
APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_NAME=radonaix_app
APP_DB_USER=radonaix
APP_DB_PASSWORD=radonaix
# Dedicated application schema (used as the connection search_path).
APP_DB_SCHEMA=administration
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# --- Redis + Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- ra-platform: ClickHouse (read-only recon data) ---
CLICKHOUSE_ENABLED=true
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=rafms

# --- ra-platform: Postgres (read-only file_log/batches) ---
RA_PG_ENABLED=true
RA_PG_HOST=localhost
RA_PG_PORT=5432
RA_PG_NAME=rafms
RA_PG_USER=postgres
RA_PG_PASSWORD=postgres

# --- ra-platform: Airflow REST (pipeline control) ---
AIRFLOW_ENABLED=false
AIRFLOW_BASE_URL=http://localhost:8081/api/v1
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow

# --- Reporting ---
REPORTS_DIR=/var/lib/radonaix/reports
