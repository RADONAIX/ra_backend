# =====================================================================
# RADONAIX backend — PRODUCTION .env template
# Copy to `.env` on the VM and fill in real values. NEVER commit the real .env.
# Used by BOTH deploy tracks (Docker Compose and bare-VM/systemd).
# =====================================================================

# --- General ---
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true
API_PREFIX=/api
# The browser origin(s) of the UI. NO "*" in production.
CORS_ORIGINS=https://ra.example.com

# --- Auth / JWT ---
# REQUIRED in production — the app REFUSES TO START otherwise:
#   * JWT_SECRET must be a unique random value, >= 32 chars (not the default).
#     generate:  python -c "import secrets; print(secrets.token_urlsafe(48))"
#   * BOOTSTRAP_ADMIN_PASSWORD must be changed from the default.
JWT_SECRET=__CHANGE_ME__generate_a_48_char_random_secret__
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
BOOTSTRAP_ADMIN_EMAIL=admin@radonaix.io
BOOTSTRAP_ADMIN_PASSWORD=__CHANGE_ME__strong_unique_password__
DEMO_PASSWORD=__CHANGE_ME__or_remove_demo_users__

# --- App database (the app's OWN data: users/roles/audit/exports) ---
# Docker track (bundled postgres): APP_DB_HOST=postgres (set in compose).
# External managed DB: point these at it and drop the postgres service.
APP_DB_HOST=postgres
APP_DB_PORT=5432
APP_DB_NAME=radonaix_app
APP_DB_USER=radonaix
APP_DB_PASSWORD=__CHANGE_ME__
APP_DB_SCHEMA=administration
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# --- Redis + Celery (REQUIRED — powers /exports; run the worker) ---
# Docker track: redis://redis:6379/... (set in compose). Bare VM: localhost.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Bulk exports ---
EXPORT_RETENTION_DAYS=7
EXPORT_MAX_CONCURRENT_PER_USER=3
EXPORT_MAX_DATE_SPAN_DAYS=31
EXPORT_CHUNK_ROWS=50000
# Where export .csv.gz files are written (must be writable; shared API<->worker).
REPORTS_DIR=/var/lib/radonaix/reports

# --- ra-platform read-only sources (ALWAYS external — never containerized) ---
CLICKHOUSE_ENABLED=true
CLICKHOUSE_HOST=10.200.37.142
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=rafms

# Pipeline batch/file logs (rafms_app) + BI report matviews (rafms/bi_reports).
RA_PG_ENABLED=true
RA_PG_HOST=10.200.37.142
RA_PG_PORT=5432
RA_PG_NAME=rafms
RA_PG_USER=postgres
RA_PG_PASSWORD=__CHANGE_ME__
RA_BI_PG_NAME=rafms
RA_BI_PG_SCHEMA=bi_reports

# --- Airflow (pipeline control) — optional ---
AIRFLOW_ENABLED=false
