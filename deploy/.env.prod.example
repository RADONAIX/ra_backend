# =====================================================================
# RADONAIX backend — PRODUCTION .env template
# Copy to the BACKEND ROOT as `.env` on the VM (not deploy/.env) and fill in
# real values. NEVER commit the real .env. Used by both deploy tracks.
# =====================================================================

# --- General ---
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true
API_PREFIX=/api
# Exact browser origin(s) of the UI — scheme+host+port, no trailing slash, no "*".
CORS_ORIGINS=https://ra.example.com

# --- Auth / JWT ---
# REQUIRED in production — the app REFUSES TO START otherwise:
#   * JWT_SECRET: unique random value, >= 32 chars (not the default).
#     generate:  python -c "import secrets; print(secrets.token_urlsafe(48))"
#   * BOOTSTRAP_ADMIN_PASSWORD: changed from the default.
JWT_SECRET=__CHANGE_ME__generate_a_48_char_random_secret__
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
BOOTSTRAP_ADMIN_EMAIL=admin@radonaix.io
BOOTSTRAP_ADMIN_PASSWORD=__CHANGE_ME__strong_unique_password__
DEMO_PASSWORD=

# --- App database (the app's OWN data: users/roles/audit/exports) ---
# Docker track (bundled postgres): APP_DB_HOST=postgres.
# Bare VM / external managed DB: set the real host (e.g. localhost).
APP_DB_HOST=postgres
APP_DB_PORT=5432
APP_DB_NAME=radonaix_app
APP_DB_USER=radonaix
APP_DB_PASSWORD=__CHANGE_ME__
APP_DB_SCHEMA=administration
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# --- Bulk exports (async report downloads) ---
# Master switch. false = API-only: no Redis/Celery worker needed, /exports -> 503.
# Set true ONLY after Redis + the worker are running (see docs/DEPLOYMENT.md).
EXPORTS_ENABLED=false

# --- Redis + Celery (ONLY needed when EXPORTS_ENABLED=true) ---
# Docker: redis://redis:6379/... (set in compose). Bare VM: localhost.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Bulk export tuning (only used when EXPORTS_ENABLED=true) ---
EXPORT_RETENTION_DAYS=7
EXPORT_MAX_CONCURRENT_PER_USER=3
EXPORT_MAX_DATE_SPAN_DAYS=31
EXPORT_CHUNK_ROWS=50000
REPORTS_DIR=/var/lib/radonaix/reports

# --- ra-platform read-only sources (ALWAYS external — never containerized) ---
CLICKHOUSE_ENABLED=true
CLICKHOUSE_HOST=10.200.37.142
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=rafms

# Pipeline batch/file logs + BI report matviews (rafms / bi_reports).
RA_PG_ENABLED=true
RA_PG_HOST=10.200.37.142
RA_PG_PORT=5432
RA_PG_NAME=rafms
RA_PG_USER=postgres
RA_PG_PASSWORD=__CHANGE_ME__
RA_BI_PG_NAME=rafms
RA_BI_PG_SCHEMA=bi_reports

# --- Airflow (pipeline retry/replay) — optional; off = actions no-op gracefully ---
AIRFLOW_ENABLED=false
